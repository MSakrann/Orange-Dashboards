# Public Supabase browser configuration. The publishable key is preferred;
# NEXT_PUBLIC_SUPABASE_ANON_KEY remains supported for legacy projects.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cloud E2E only. Use an administrator in a dedicated test project/workspace.
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
E2E_WORKSPACE_SLUG=hot-topics

# Optional: run cloud E2E against an already deployed application.
E2E_BASE_URL=
