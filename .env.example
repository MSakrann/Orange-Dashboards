# Public Supabase browser configuration. The publishable key is preferred;
# NEXT_PUBLIC_SUPABASE_ANON_KEY remains supported for legacy projects.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only credentials (Vercel: Production + Preview). Never expose in the browser.
SUPABASE_SERVICE_ROLE_KEY=
CRON_SECRET=

# PE Development workspace -> first Jira Cloud instance
JIRA_PE_BASE_URL=https://your-company.atlassian.net
JIRA_PE_EMAIL=
JIRA_PE_API_TOKEN=
JIRA_PE_JQL=project = PE ORDER BY updated DESC
JIRA_PE_WEBHOOK_SECRET=
# Optional numeric custom field id for progress percentage, e.g. customfield_10042
JIRA_PE_PROGRESS_FIELD_ID=

# Platform Development workspace -> second Jira Cloud instance
JIRA_PLATFORM_BASE_URL=https://your-other-company.atlassian.net
JIRA_PLATFORM_EMAIL=
JIRA_PLATFORM_API_TOKEN=
JIRA_PLATFORM_JQL=project = PLATFORM ORDER BY updated DESC
JIRA_PLATFORM_WEBHOOK_SECRET=
JIRA_PLATFORM_PROGRESS_FIELD_ID=

# Cloud E2E only. Use an administrator in a dedicated test project/workspace.
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
E2E_WORKSPACE_SLUG=hot-topics

# Optional: run cloud E2E against an already deployed application.
E2E_BASE_URL=
